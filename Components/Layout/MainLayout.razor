@inherits LayoutComponentBase
@inject ThemeService ThemeService

<MudThemeProvider Theme="AppTheme.Default" IsDarkMode="ThemeService.IsDarkMode" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <AppHeader OnMenuClick="DrawerToggle" IsDarkMode="ThemeService.IsDarkMode" OnThemeToggle="async val => await ThemeService.SetDarkModeAsync(val)" />
    <AppDrawer Open="_drawerOpen" OpenChanged="val => _drawerOpen = val" OnToggle="DrawerToggle" />
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ThemeService.InitializeAsync();
            StateHasChanged();
        }
    }

    void DrawerToggle() => _drawerOpen = !_drawerOpen;
}
